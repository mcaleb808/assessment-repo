# Copy to apps/api/.env and fill in. Never commit the real .env.

# --- LLM provider ---
OPENAI_API_KEY=

# --- MCP server ---
# Transport: "streamable_http" (default), "sse", or "stdio"
MCP_TRANSPORT=streamable_http
# Full URL the MCP server is reachable at (used for streamable_http and sse)
MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
# Stdio only: command + space-separated args, e.g. "uv run mcp-server-fetch"
MCP_STDIO_COMMAND=
MCP_STDIO_ARGS=

# --- Model ---
MODEL=gpt-4o-mini

# --- Observability (LangFuse, optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Local dev only ---
LOG_LEVEL=INFO
